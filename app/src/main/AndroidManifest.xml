<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- Media capture -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Bluetooth audio (headsets) -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Keep cam/mic + media session alive while the app is backgrounded
         during a meeting. Required since API 29; Android 14 additionally
         requires the FOREGROUND_SERVICE_* type permissions. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Screen-share capture: API 34+ requires the mediaProjection FGS type
         permission. The SDK's ScreenCaptureService runs with this type. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- Required on API 33+ to show the "meeting in progress" notification
         that pins the foreground service. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Lets us draw the "stop screen share" floating button on top of the
         desktop / other apps while the user is screen-sharing. Granted
         explicitly by the user via Settings > Special app access on API 23+. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="true" />

    <application
        android:name=".JusiMeetApp"
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.JusiMeet"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|uiMode"
            android:supportsPictureInPicture="true"
            android:theme="@style/Theme.JusiMeet"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.ConferenceForegroundService"
            android:exported="false"
            android:foregroundServiceType="camera|microphone|mediaPlayback" />

        <!-- LiveKit ships a bound helper service that pins the MediaProjection
             session while we screen-share. We only need to declare it with the
             right foregroundServiceType — the SDK handles bind/start/stop. -->
        <service
            android:name="io.livekit.android.room.track.screencapture.ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

    </application>

</manifest>
